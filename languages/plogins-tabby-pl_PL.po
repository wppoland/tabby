#. Plugin Name of the plugin
#: tabby.php
msgid "Tabby - Custom Product Tabs for WooCommerce"
msgstr "Tabby - Własne zakładki produktów dla WooCommerce"

#. Plugin URI of the plugin
#: tabby.php
msgid "https://plogins.com/tabby/"
msgstr "https://plogins.com/tabby/"

#. Description of the plugin
#: tabby.php
msgid "Add custom tabs with your own content to WooCommerce product pages."
msgstr ""
"Dodawaj własne zakładki z własną treścią do stron produktów WooCommerce."

#. Author of the plugin
#: tabby.php
msgid "WPPoland"
msgstr "WPPoland"

#. Author URI of the plugin
#: tabby.php
msgid "https://plogins.com/"
msgstr "https://plogins.com/"

#: src/Admin/Settings.php:57
msgid "Tabby - Custom Product Tabs"
msgstr "Tabby - Własne zakładki produktów"

#: src/Admin/Settings.php:58
msgid "Tabby Tabs"
msgstr "Zakładki Tabby"

#: src/Admin/Settings.php:102
msgid "Reusable tabs for every product page"
msgstr "Zakładki wielokrotnego użytku dla każdej strony produktu"

#: src/Admin/Settings.php:103
msgid ""
"Define tabs once and they appear on all single product pages, after the "
"native WooCommerce tabs. Basic HTML is allowed in tab content."
msgstr ""
"Zdefiniuj zakładki raz, a pojawią się na wszystkich stronach pojedynczych "
"produktów, za natywnymi zakładkami WooCommerce. W treści zakładek dozwolony "
"jest podstawowy kod HTML."

#: src/Admin/Settings.php:111
msgid "General"
msgstr "Ogólne"

#: src/Admin/Settings.php:115
msgid "Enable Tabby"
msgstr "Włącz Tabby"

#: src/Admin/Settings.php:126
msgid "Render custom tabs on single product pages."
msgstr "Renderuj własne zakładki na stronach pojedynczych produktów."

#: src/Admin/Settings.php:129
msgid ""
"Master switch. Turn this off to hide every tab below at once without "
"deleting them, your tabs stay saved and reappear when you turn it back on."
msgstr ""

#: src/Admin/Settings.php:138
msgid "Tabs"
msgstr "Zakładki"

#: src/Admin/Settings.php:139
msgid ""
"Each tab shows on every product page, below the native WooCommerce tabs, in "
"the order listed here. A row with no title is dropped when you save, so "
"leave a blank row to discard it."
msgstr ""

#: src/Admin/Settings.php:160
msgid "Add tab"
msgstr "Dodaj zakładkę"

#: src/Admin/Settings.php:183
msgid "Tab title"
msgstr "Tytuł zakładki"

#: src/Admin/Settings.php:189
msgid "e.g. Shipping & Returns"
msgstr "np. Wysyłka i zwroty"

#: src/Admin/Settings.php:199
msgid "Enabled"
msgstr "Włączona"

#: src/Admin/Settings.php:200
msgid "shows this tab on the storefront; uncheck to hide just this one"
msgstr ""

#: src/Admin/Settings.php:204
msgid "Remove this tab"
msgstr "Usuń tę zakładkę"

#: src/Admin/Settings.php:208
msgid "Tab content"
msgstr "Treść zakładki"

#: src/Admin/Settings.php:213
msgid "Basic HTML is allowed (links, lists, bold, etc.)."
msgstr "Dozwolony jest podstawowy kod HTML (linki, listy, pogrubienie itp.)."

#. translators: %s: an example HTML snippet shown as inline guidance.
#: src/Admin/Settings.php:219
#, php-format
msgid ""
"Same HTML as a post, e.g. %s. Scripts and unsafe tags are stripped on save."
msgstr ""

#: tabby.php:48
msgid ""
"Tabby - Custom Product Tabs for WooCommerce requires WooCommerce to be "
"active."
msgstr ""
"Tabby - Własne zakładki produktów dla WooCommerce wymaga aktywnej wtyczki "
"WooCommerce."

#~ msgid "These tabs appear on every product, in the order listed here."
#~ msgstr ""
#~ "Te zakładki pojawiają się przy każdym produkcie, w kolejności podanej "
#~ "tutaj."
